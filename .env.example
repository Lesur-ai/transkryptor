# Port pour le serveur Node.js
PORT=3000

# Clé API pour Cloud Temple LLMaaS (SecNumCloud)
CLOUD_TEMPLE_API_KEY=votre_cle_api_cloud_temple

# Modèles d'analyse/synthèse proposés dans l'interface (ordre = priorité)
CLOUD_TEMPLE_ALLOWED_MODELS=qwen3.6:27b,mistral-small4:119b,qwen3.6:35b-a3b,gemma4:31b
